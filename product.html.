<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <title>Motorola Edge 50 - Patalix Shopee</title>
    <style>
        body { font-family: sans-serif; background: #fff; margin: 0; padding: 15px; }
        .product-card { border: 1px solid #ddd; border-radius: 15px; padding: 20px; text-align: center; }
        .price { font-size: 24px; color: #000; font-weight: bold; }
        .emi-box { background: #f1f8ff; padding: 10px; border-radius: 8px; margin: 15px 0; border-left: 5px solid #003399; }

        .zara-advice { color: #0084ff; font-style: italic; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="product-card">
        <img src="https://via.placeholder.com/200x300" alt="Motorola Phone">
        <h2>Motorola Edge 50 Pro</h2>
        <p class="price">₹29,999</p>
        
        <div class="emi-box">
            <strong>EMI / Installments</strong><br>
            ₹2,500/month for 12 months
        </div>

        <button class="buy-btn">Buy Now (Flipkart Checkout)</button>
        
        <p class="zara-advice">✨ Zara: "Gaurav, yeh phone aapki budget mein best hai!"</p>
    </div>
</body>
</html>

